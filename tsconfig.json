{
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./lib",
    "pretty": true,
    "target": "es2021",
    "module": "commonjs",
    "sourceMap": true,
    "declaration": true,
    "strict": true,
    "noImplicitAny": false,
    "noUnusedLocals": true,
    "noImplicitReturns": true,
    "types": ["node", "jest"]
  },
  "include": ["./lib/*"]
}
